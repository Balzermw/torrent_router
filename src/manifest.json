{
  "name": "Synology Torrent Router",
  "version": "3.22.1",
  "description": "Chrome extension for routing authenticated torrent downloads to Synology Download Station",
  "manifest_version": 3,
  "default_locale": "en",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "64": "assets/icons/icon-64.png",
    "128": "assets/icons/icon-128.png",
    "256": "assets/icons/icon-256.png"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "entry/background.entry.js"
  },
  "action": {
    "default_title": "Synology Download Station",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "64": "assets/icons/icon-64.png",
      "128": "assets/icons/icon-128.png",
      "256": "assets/icons/icon-256.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://iptorrents.com/*",
        "*://*.iptorrents.com/*",
        "*://torrentleech.org/*",
        "*://*.torrentleech.org/*",
        "*://torrentleech.cc/*",
        "*://*.torrentleech.cc/*",
        "*://myanonamouse.net/*",
        "*://*.myanonamouse.net/*"
      ],
      "js": ["entry/contentScript.entry.js"]
    }
  ],
  "permissions": ["scripting", "contextMenus", "notifications", "storage", "tabs", "downloads", "sidePanel"],
  "host_permissions": [
    "*://iptorrents.com/*",
    "*://*.iptorrents.com/*",
    "*://torrentleech.org/*",
    "*://*.torrentleech.org/*",
    "*://torrentleech.cc/*",
    "*://*.torrentleech.cc/*",
    "*://myanonamouse.net/*",
    "*://*.myanonamouse.net/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "web_accessible_resources": [
    {
      "resources": ["*.html"],
      "matches": [
        "*://iptorrents.com/*",
        "*://*.iptorrents.com/*",
        "*://torrentleech.org/*",
        "*://*.torrentleech.org/*",
        "*://torrentleech.cc/*",
        "*://*.torrentleech.cc/*",
        "*://myanonamouse.net/*",
        "*://*.myanonamouse.net/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
